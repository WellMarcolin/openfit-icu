{
  "name": "openfit-icu",
  "version": "1.0.0",
  "description": "Training dashboard powered by Intervals.icu with OpenCode AI assistant",
  "private": true,
  "type": "module",
  "author": "OpenFit ICU Team",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.8",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.23",
    "@fontsource-variable/inter": "5.2.8",
